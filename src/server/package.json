{
  "name": "@overseer/server",
  "version": "2.0.3",
  "author": "Michael DeBerry",
  "license": "GNU Affero General Public License v3.0",
  "private": true,
  "scripts": {
    "build": "npm run build:remote --prefix ../client && tsc -P ./tsconfig.json",
    "start": "npm run build:remote:dev --prefix ../client && node ./node_modules/nodemon/bin/nodemon.js -e ../**/*.ts --exec \"ts-node -P ./tsconfig.json ./src/server.ts || exit 1\"",
    "lint": "eslint ./src --ext ts",
    "lint:fix": "eslint ./src -c ./.eslintrc.json --ext ts --fix"
  },
  "dependencies": {
    "@overseer/common": "file:../common",
    "compression": "^1.7.4",
    "express": "^4.17.1",
    "ws": "^7.3.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.0",
    "@types/express": "^4.17.7",
    "@types/node": "^14.0.27",
    "@types/ws": "^7.2.6",
    "@typescript-eslint/eslint-plugin": "^2.34.0",
    "@typescript-eslint/parser": "^2.34.0",
    "eslint": "^7.6.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "nodemon": "^2.0.4",
    "prettier": "^2.0.5",
    "ts-node": "^8.10.2",
    "typescript": "^3.9.7"
  },
  "engines": {
    "node": ">=10.0.0"
  }
}
